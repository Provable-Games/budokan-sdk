# --- Required ---

# From @BotFather
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-token

# Bot's public HTTPS URL — Cartridge redirects the user's browser to
# BOT_PUBLIC_URL/api/connect/:token/callback after they authorize.
# In dev: an ngrok URL like https://abc123.ngrok-free.app
# In prod: your deployed bot domain
BOT_PUBLIC_URL=https://your-bot.example.com

# --- Optional (defaults shown) ---

# mainnet | sepolia
BUDOKAN_CHAIN=mainnet

# Local HTTP listen port for the bot's API
# BOT_HTTP_PORT=8787

# Filesystem path for session storage (gitignored)
# BOT_DATA_DIR=./data

# SDK endpoint overrides — leave unset to use chain presets
# BUDOKAN_API_URL=
# BUDOKAN_WS_URL=
# BUDOKAN_RPC_URL=
# BUDOKAN_ADDRESS=
# BUDOKAN_VIEWER_ADDRESS=

# Optional. Voyager API proxy URL — same proxy budokan.gg uses to fetch
# token balances. Powers the prize-sponsorship picker in /create and the
# balances shown by /wallet. Defaults to the shared proxy below, so you
# normally only need to set the TOKEN. Set the URL to point at your own proxy.
# BUDOKAN_VOYAGER_PROXY_URL=https://pg-voyager-proxy.up.railway.app
#
# Required when calling the proxy from server-side (no Origin header).
# Must match one of the comma-separated values in the proxy's
# PROXY_AUTH_TOKENS env var. Without it, the proxy responds 401.
# BUDOKAN_VOYAGER_PROXY_TOKEN=replace-with-shared-secret
#
# Optional. Where to post bracket cards + live updates. Easiest: add the bot to
# the group and run /bracket_channel there — no env var needed. This env var is
# an alternative; if both are set, /bracket_channel wins. Unset + no command =
# updates go to the organizer's DM.
# BRACKET_CHANNEL_ID=-1001234567890

# Optional. A funded Starknet account (private key + address) the bot uses to
# ADVANCE brackets — entering each round's winners into the next match on their
# behalf — so progression never depends on the organizer's session staying
# alive. Entering tournaments is permissionless (no fund access); the account
# only needs a little STRK for gas. Without it, advancement falls back to the
# organizer's session (and DMs them to /connect if it has expired).
# BOT_OPERATOR_PRIVATE_KEY=0x...
# BOT_OPERATOR_ADDRESS=0x...
