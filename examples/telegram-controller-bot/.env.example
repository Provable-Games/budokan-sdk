# --- Required ---

# From @BotFather
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-token

# Bot's public HTTPS URL (the Mini App POSTs here)
# In dev: an ngrok URL like https://abc123.ngrok-free.app
# In prod: your deployed bot domain
BOT_PUBLIC_URL=https://your-bot.example.com

# Mini App's public URL (registered with @BotFather as the bot's web_app)
# In dev: http://localhost:5173 (Vite dev server)
# In prod: your deployed static site
MINIAPP_URL=https://your-miniapp.example.com

# --- Optional (defaults shown) ---

# mainnet | sepolia
BUDOKAN_CHAIN=mainnet

# Local HTTP listen port for the bot's API
# BOT_HTTP_PORT=8787

# Filesystem path for session storage (gitignored)
# BOT_DATA_DIR=./data

# SDK endpoint overrides — leave unset to use chain presets
# BUDOKAN_API_URL=
# BUDOKAN_WS_URL=
# BUDOKAN_RPC_URL=
# BUDOKAN_ADDRESS=
# BUDOKAN_VIEWER_ADDRESS=

# Optional. Voyager API proxy URL — same proxy budokan.gg uses to fetch
# token balances. Required for the prize-sponsorship picker in /create
# (lets the bot show what's in your wallet). If unset, prize sponsorship
# is disabled at create time.
# BUDOKAN_VOYAGER_PROXY_URL=https://budokan-production.up.railway.app
