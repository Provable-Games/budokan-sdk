# Public URL of the bot's HTTP API. The Mini App fetches policies and
# posts the session bundle here.
#
# In dev: an ngrok URL (must be HTTPS in production), e.g.
#   VITE_BOT_PUBLIC_URL=https://abc123.ngrok-free.app
# In prod: your deployed bot domain.
VITE_BOT_PUBLIC_URL=https://your-bot.example.com
