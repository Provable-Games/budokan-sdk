# Telegram Bot API token from @BotFather (required).
TELEGRAM_BOT_TOKEN=

# Chain preset the SDK reads from: "mainnet" (default) or "sepolia".
# Determines the API/WebSocket endpoints and the deeplink network.
BUDOKAN_CHAIN=mainnet

# Optional: override the chain preset's API base URL. Only needed when you run
# against a non-default Budokan API deployment. Leave unset otherwise.
# BUDOKAN_API_BASE_URL=https://budokan-api-production.up.railway.app
