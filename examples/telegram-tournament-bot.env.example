TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token

# Optional. Defaults to mainnet and the SDK's built-in endpoints.
BUDOKAN_CHAIN=mainnet
# BUDOKAN_API_URL=
# BUDOKAN_WS_URL=
# BUDOKAN_RPC_URL=
# BUDOKAN_ADDRESS=
# BUDOKAN_VIEWER_ADDRESS=

# Optional. Public web URL used for /play and /claim deeplinks.
# Defaults to https://budokan.gg
# BUDOKAN_WEB_URL=https://budokan.gg

# Optional. Defaults to .telegram-tournament-bot-registrations.json in the repo root.
# REGISTRATIONS_FILE=.telegram-tournament-bot-registrations.json
